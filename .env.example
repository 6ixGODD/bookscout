# BookScout environment configuration template.
# Copy this file to .env and fill in your API keys.
# DO NOT commit .env to version control.

# LLM (DeepSeek, OpenAI-compatible)
BOOKSCOUT_CHATMODEL__API_KEY=
BOOKSCOUT_CHATMODEL__BASE_URL=https://api.deepseek.com
BOOKSCOUT_CHATMODEL__MODEL=deepseek-v4-flash

# Embedding (DashScope, OpenAI-compatible)
BOOKSCOUT_EMBEDDING__API_KEY=
BOOKSCOUT_EMBEDDING__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BOOKSCOUT_EMBEDDING__MODEL=text-embedding-v4

# MinerU PDF parsing API
BOOKSCOUT_MINERU__API_TOKEN=
