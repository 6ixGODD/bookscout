# Repository defaults
* text=auto eol=lf

# Generated and lock files should not skew code review or language statistics.
**/generated/** linguist-generated=true
**/__generated__/** linguist-generated=true
docs/reference/** linguist-generated=true
uv.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true
**/pnpm-lock.yaml linguist-generated=true
package-lock.json linguist-generated=true
**/package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
**/yarn.lock linguist-generated=true

# Python
*.py text eol=lf diff=python
*.pyi text eol=lf diff=python
*.ipynb text eol=lf

# Go
*.go text eol=lf
go.sum text eol=lf linguist-generated=true
go.work.sum text eol=lf linguist-generated=true

# Web
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.svelte text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf

# Version
VERSION text eol=lf

# Data, config, and docs
*.csv text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf diff=markdown
*.mdx text eol=lf diff=markdown
*.rst text eol=lf
*.txt text eol=lf

# Scripts and build files
*.sh text eol=lf
scripts/**/*.sh text eol=lf
scripts/**/*.py text eol=lf diff=python
Makefile text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Git and editor metadata
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf
.prettierignore text eol=lf
.eslintrc text eol=lf
.eslintignore text eol=lf
.stylelintrc text eol=lf

# Lock files
*.lock text eol=lf linguist-generated=true

# Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.svg text eol=lf

# Audio, video, fonts, and WebAssembly
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.webm binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.wasm binary

# Documents and archives
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.7z binary
*.gz binary

# Models and large binary artifacts
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
*.model filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.tflite filter=lfs diff=lfs merge=lfs -text
*.pb filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.sav filter=lfs diff=lfs merge=lfs -text

# Fonts and icons
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.ico filter=lfs diff=lfs merge=lfs -text
